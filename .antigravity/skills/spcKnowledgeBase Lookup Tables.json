        "formulas": {
            "capabilityWithin": {
                "index": "Cpk",
                "description": "Nutzt sigma_within, geschätzt über Teilgruppen.",
                "formula": "min((USL - mu) / (3 * sigma_within), (mu - LSL) / (3 * sigma_within))",
                "sigmaEstimation": "R_bar / d2"
            },
            "capabilityOverall": {
                "index": "Ppk",
                "description": "Nutzt die Gesamt-Standardabweichung (s) aller Datenpunkte.",
                "formula": "min((USL - x_bar) / (3 * s), (x_bar - LSL) / (3 * s))"
            },
            "approximations": {
                "d2ForNGreaterThan25": "sqrt(2n - 1) - 0.5"
            }
